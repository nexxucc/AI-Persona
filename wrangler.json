
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ai-persona",
	"main": "./src/worker/index.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"vars": {
		"APP_ENV": "production"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "persona-db-prod",
			"database_id": "3a1394e2-40be-4c48-a0f3-f37cbc5fbd9f",
			"migrations_dir": "migrations"
		}
	],
	"env": {
		"development": {
			"vars": {
				"APP_ENV": "development"
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "persona-db-dev",
					"database_id": "01baea77-276d-4462-9e78-d34a7bff1cf5",
					"migrations_dir": "migrations",
					"remote": true
				}
			],
			"vectorize": [
				{
					"binding": "VECTORIZE",
					"index_name": "persona-vectors-dev",
					"remote": true
				}
			]
		}
	},
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/api/*"]
	}
	
	
	
	
	
	
	
}
